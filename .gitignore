# --- OS cruft ---
.DS_Store
Thumbs.db

# --- IDE / tooling ---
.idea/
.vscode/
*.iml
.bloop/
.bsp/
.metals/
metals.sbt

# --- sbt / Scala build outputs ---
target/
project/target/
project/project/

# --- Logs ---
logs/
*.log

# --- Local configs (user-specific) ---
conf/big.conf
# If you create more machine-specific files, ignore them here:
conf/*.local.conf

# --- Generated artifacts (created by running the app) ---
# Ignore everything under out/, but keep CSVs in out/stats/
out/**
!out/.gitkeep
!out/stats/
out/stats/**
!out/stats/*.csv

# Keep MapReduce outputs ignored
out_mr_out/
out_mr_mr_out/

# --- JARs (if you build fat jars locally) ---
*.jar
