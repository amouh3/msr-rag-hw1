app { job = "extract-chunk-smoke" }
io  {
  pdfListFile = "E:/msr_data/msr_pdfs.txt"
  workDir     = "E:/msr_data/artifacts"
}
embed {
  model = "mxbai-embed-large"
  batch = 8
}
index {
  out = "E:/msr_data/artifacts/index.csv"   # where we’ll save vectors
  maxDocs = 50                               # bump to all later
}
